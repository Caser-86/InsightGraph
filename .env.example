# InsightGraph 环境变量模板
# 复制此文件为 .env 并填入实际值

# ---- API 安全 ----
# 设置后所有非 /health 接口需要 Bearer 或 X-API-Key 认证
INSIGHT_GRAPH_API_KEY=replace-me-with-strong-random-key

# ---- LLM 配置 (DeepSeek) ----
INSIGHT_GRAPH_LLM_PROVIDER=openai_compatible
INSIGHT_GRAPH_LLM_BASE_URL=https://api.deepseek.com/v1
INSIGHT_GRAPH_LLM_API_KEY=sk-your-deepseek-api-key
INSIGHT_GRAPH_LLM_MODEL=deepseek-reasoner

# ---- LLM 路由（混合模型策略） ----
INSIGHT_GRAPH_LLM_ROUTER=rules
# 快速模型：相关性判断、简单任务
INSIGHT_GRAPH_LLM_MODEL_FAST=deepseek-v4-flash
# 默认模型：一般任务
INSIGHT_GRAPH_LLM_MODEL_DEFAULT=deepseek-reasoner
# 强力模型：报告生成、审稿润色
INSIGHT_GRAPH_LLM_MODEL_STRONG=deepseek-v4-pro
# 路由字符数阈值
INSIGHT_GRAPH_LLM_ROUTER_FAST_CHAR_THRESHOLD=2000
INSIGHT_GRAPH_LLM_ROUTER_STRONG_CHAR_THRESHOLD=12000
# LLM 最大输出 token
INSIGHT_GRAPH_LLM_MAX_OUTPUT_TOKENS=64000

# ---- 搜索引擎配置 ----
INSIGHT_GRAPH_SEARCH_PROVIDER=duckduckgo
INSIGHT_GRAPH_SEARCH_PROVIDERS=duckduckgo
INSIGHT_GRAPH_SEARCH_LIMIT=80
INSIGHT_GRAPH_MAX_COLLECTION_ROUNDS=8
INSIGHT_GRAPH_MAX_FETCHES=500
# SerpAPI（按需开启，key 留空则不启用）
INSIGHT_GRAPH_SERPAPI_KEY=
# SerpAPI 限额（控制成本）
# INSIGHT_GRAPH_SERPAPI_DAILY_CALL_LIMIT=20
# INSIGHT_GRAPH_SERPAPI_PER_RUN_LIMIT=5
# Google CSE（按需开启，key 和 CSE ID 留空则不启用）
# INSIGHT_GRAPH_GOOGLE_API_KEY=
# INSIGHT_GRAPH_GOOGLE_CSE_ID=

# ---- 研究质量 ----
INSIGHT_GRAPH_REPORT_INTENSITY=standard
# 报告/分析师/审稿 provider
INSIGHT_GRAPH_REPORTER_PROVIDER=llm
INSIGHT_GRAPH_ANALYST_PROVIDER=llm
INSIGHT_GRAPH_REPORT_REVIEW_PROVIDER=llm
INSIGHT_GRAPH_REPORT_REVIEW_MAX_PASSES=2
# 最大研究重试次数
INSIGHT_GRAPH_MAX_RESEARCH_RETRIES=3
# 严格质量门控
INSIGHT_GRAPH_STRICT_QUALITY_GATE=1
INSIGHT_GRAPH_MIN_TOPIC_COVERAGE_RATIO=0.80
# 证据阈值
INSIGHT_GRAPH_MIN_SUCCESS_EVIDENCE=8
INSIGHT_GRAPH_MIN_SUCCESS_VERIFIED_EVIDENCE=8
INSIGHT_GRAPH_MIN_SUCCESSFUL_LLM_CALLS=2
INSIGHT_GRAPH_MIN_SUCCESS_REPORT_CHARS=2000
# 相关性过滤
INSIGHT_GRAPH_RELEVANCE_FILTER=1
INSIGHT_GRAPH_RELEVANCE_JUDGE=deterministic
INSIGHT_GRAPH_CITATION_JUDGE_PROVIDER=lexical

# ---- 数据采集 ----
INSIGHT_GRAPH_USE_GITHUB_SEARCH=1
INSIGHT_GRAPH_USE_SEC_FILINGS=1
INSIGHT_GRAPH_USE_SEC_FINANCIALS=1
INSIGHT_GRAPH_USE_NEWS_SEARCH=1
INSIGHT_GRAPH_USE_WEB_SEARCH=1
INSIGHT_GRAPH_MULTI_SOURCE_COLLECTION=1

# ---- 任务持久化 ----
INSIGHT_GRAPH_RESEARCH_JOBS_BACKEND=sqlite
INSIGHT_GRAPH_RESEARCH_JOBS_SQLITE_PATH=/data/research_jobs.db
INSIGHT_GRAPH_RESEARCH_JOBS_STARTUP_WORKER=1

# ---- 可观测性 ----
# trace 记录模式：metadata-only（推荐：不记录完整 prompt/completion）
INSIGHT_GRAPH_LLM_TRACE_FULL=0
# checkpoint 恢复
INSIGHT_GRAPH_CHECKPOINT_RESUME=0

# ---- 预算 ----
INSIGHT_GRAPH_MAX_TOKENS=2000000
